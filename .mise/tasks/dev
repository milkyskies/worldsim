#!/bin/bash
#MISE description="Run worldsim (Bevy dev build)"
#MISE usage="dev [worktree-num]"
set -euo pipefail

# Resolve the main repo so we can find sibling worktrees regardless of cwd.
MAIN_REPO="$(cd "$(git rev-parse --git-common-dir)/.." && pwd)"

WT_NAME="main"
if [ -n "${1:-}" ]; then
    WT_DIR="$MAIN_REPO/../worldsim-worktrees/$1"
    if [ ! -d "$WT_DIR" ]; then
        echo "Worktree $1 not found at $WT_DIR" >&2
        exit 1
    fi
    cd "$WT_DIR"
    WT_NAME="$1"
fi

# Build and run using .cargo/config.toml's shared target dir. We intentionally
# do NOT set CARGO_TARGET_DIR here — cargo embeds the effective target path in
# artifact fingerprint hashes, so a per-worktree override changes every hash
# and triggers a full cold rebuild (~10 min) instead of incremental (~30-60s).
#
# All worktrees share the same target dir; cargo's file-locking prevents
# concurrent build corruption. There is no binary-collision risk: once exec'd,
# a running process holds its file inode open, so a concurrent build that
# overwrites target/debug/worldsim does not affect it.
#
# cargo run also sets DYLD_LIBRARY_PATH (macOS) / LD_LIBRARY_PATH (Linux)
# before executing, so dynamic libs (libstd, libbevy_dylib) are found
# automatically — something a raw exec of a copied binary would miss.
cargo run
